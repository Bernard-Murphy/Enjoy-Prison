PORT=4001

# OpenAI-compatible API (required for plan/build/modify).
# Use OPENAI_BASE_URL for other providers (e.g. Venice, OpenRouter).
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# S3 / MinIO (required for build)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=epgames
# For MinIO: use http://localhost:9000
S3_ENDPOINT=

# Public URL prefix for hosted games (e.g. https://cdn.example.com)
GAME_BASE_URL=
