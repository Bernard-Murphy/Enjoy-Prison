# Database
DATABASE_URL="postgresql://epgames:epgames@localhost:5432/epgames"

# JWT (change in production)
JWT_SECRET="epgames-jwt-secret-key-change-me"

# Google reCAPTCHA Enterprise v3 (optional). When set, registration and game creation require verification.
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=   # Site key (client)
# RECAPTCHA_API_KEY=                # API key for reCAPTCHA Enterprise
# RECAPTCHA_PROJECT_ID=             # Google Cloud project ID (required when RECAPTCHA_API_KEY is set)

# Base URL of this web app (for build callbacks from game-service). Required for Build to work.
# WEB_APP_URL=http://localhost:3000

# Game service (for plan generation and build). When set, planning and build will call this service.
# GAME_SERVICE_URL=http://localhost:4001

# Optional: OpenAI for AI features (game-service uses its own key)
# OPENAI_API_KEY=
